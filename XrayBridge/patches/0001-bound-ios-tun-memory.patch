+	tcpipErr = dev.stack.SetTransportProtocolOption(tcp.ProtocolNumber, &receiveBufferOpt)
+	if tcpipErr != nil {
+		return nil, nil, nil, fmt.Errorf("could not bound TCP receive buffers: %v", tcpipErr)
+	}
+	sendBufferOpt := tcpip.TCPSendBufferSizeRangeOption{
+		Min:     tcp.MinBufferSize,
+		Default: netstackTCPBufferSize,
+		Max:     netstackTCPBufferSize,
+	}
+	tcpipErr = dev.stack.SetTransportProtocolOption(tcp.ProtocolNumber, &sendBufferOpt)
+	if tcpipErr != nil {
+		return nil, nil, nil, fmt.Errorf("could not bound TCP send buffers: %v", tcpipErr)
+	}
